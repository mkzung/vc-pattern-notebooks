# Data — raw pulls are gitignored; the user re-fetches via scripts/fetch_data.py.
# The committed sample_* files are CI fixtures used by .github/workflows/ci.yml.
data/raw/*
!data/raw/.gitkeep
!data/raw/sample_unicorns.csv
!data/raw/sample_founders.csv
!data/raw/sample_fetch_log.json

